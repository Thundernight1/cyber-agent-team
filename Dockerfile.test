# Build stage for test dependencies
FROM python:3.11-slim as test-builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --user --no-cache-dir -r requirements.txt && \
    pip install --user --no-cache-dir \
    pytest \
    pytest-cov \
    pytest-asyncio \
    flake8 \
    black \
    isort \
    bandit \
    safety

# Test stage
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 appuser

# Copy dependencies from builder (root-owned, read+exec for all)
COPY --from=test-builder --chown=root:root --chmod=755 /root/.local /home/appuser/.local

ENV PATH=/home/appuser/.local/bin:$PATH \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

COPY --chown=root:root --chmod=755 . .

USER appuser

# Default command
CMD ["pytest", "tests/", "-v", "--cov=.", "--cov-report=html", "--cov-report=term-missing"]
