# ============================================================
# Cyber Agent Team - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun
# ============================================================

# Ollama Cloud API Key
OLLAMA_API_KEY=your_ollama_api_key_here

# Shodan API Key (optional)
SHODAN_API_KEY=

# Tool paths for local installations (optional)
NMAP_PATH=nmap
NIKTO_PATH=nikto
SQLMAP_PATH=sqlmap
NUCLEI_PATH=nuclei
ZAP_PATH=zap-cli
TRIVY_PATH=trivy
METASPLOIT_PATH=msfconsole
SHODAN_PATH=shodan
BURPSUITE_PATH=burpsuite

# Local binary paths (optional)
FLIPPER_PATH=flipper
TCPDUMP_PATH=tcpdump

# Enable physical tools only when needed
PHYSICAL_TOOLS_ENABLED=false
PHYSICAL_TOOLS=wifi_pineapple,flipper_zero,sharktap

# Wi-Fi Pineapple host (optional)
PINEAPPLE_HOST=172.16.42.1

# Flipper Zero serial port (optional)
FLIPPER_PORT=/dev/ttyACM0

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8443

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
